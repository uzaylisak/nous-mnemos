{
  "name": "nous-mnemos-contracts",
  "version": "0.1.0",
  "private": true,
  "description": "NousRecord — on-chain registry for Nous Mnemos AI conversation records",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:base-sepolia": "hardhat run scripts/deploy.js --network baseSepolia",
