    "attester:add": "hardhat run scripts/addAttester.js --network baseSepolia",
    "attester:revoke": "hardhat run scripts/revokeAttester.js --network baseSepolia",
    "verify": "hardhat verify --network baseSepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.17"
  }
}
