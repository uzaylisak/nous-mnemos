# Wallet that will deploy & own the NousRecord contract (Base Sepolia).
# Do NOT commit the real .env file. Put a testnet-only key here.
DEPLOYER_PRIVATE_KEY=

# Optional — override the default Base Sepolia RPC.
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Optional — for automatic source verification on BaseScan.
BASESCAN_API_KEY=

# After deployment, paste the contract address here so scripts and the web
# app can read it. The web app also exposes this under Settings → Network.
NOUS_RECORD_ADDRESS=

# The attester backend's signing address. addAttester.js reads this.
ATTESTER_ADDRESS=
